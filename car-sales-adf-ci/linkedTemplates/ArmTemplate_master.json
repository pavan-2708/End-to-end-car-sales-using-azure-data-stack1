{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "car-sales-adf-ci"
		},
		"ds_adls_parquet_sink_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ds_adls_parquet_sink'"
		},
		"ls_sql_sink_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_sql_sink'"
		},
		"ds_adls_parquet_sink_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://carsalesadls.dfs.core.windows.net/"
		},
		"ls_http_git_src_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://raw.githubusercontent.com/"
		},
		"ls_sql_sink_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "car-sales-server0101.database.windows.net"
		},
		"ls_sql_sink_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "car-sales-db"
		},
		"ls_sql_sink_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "pavan"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "car-sales-adf-ci_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ds_adls_parquet_sink_accountKey": {
						"value": "[parameters('ds_adls_parquet_sink_accountKey')]"
					},
					"ls_sql_sink_password": {
						"value": "[parameters('ls_sql_sink_password')]"
					},
					"ds_adls_parquet_sink_properties_typeProperties_url": {
						"value": "[parameters('ds_adls_parquet_sink_properties_typeProperties_url')]"
					},
					"ls_http_git_src_properties_typeProperties_url": {
						"value": "[parameters('ls_http_git_src_properties_typeProperties_url')]"
					},
					"ls_sql_sink_properties_typeProperties_server": {
						"value": "[parameters('ls_sql_sink_properties_typeProperties_server')]"
					},
					"ls_sql_sink_properties_typeProperties_database": {
						"value": "[parameters('ls_sql_sink_properties_typeProperties_database')]"
					},
					"ls_sql_sink_properties_typeProperties_userName": {
						"value": "[parameters('ls_sql_sink_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}